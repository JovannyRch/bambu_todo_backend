generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String   @id @default(uuid())
  nombre             String
  email              String   @unique
  password           String
  todos              Todo[]
  fechaCreacion      DateTime @default(now())
  fechaActualizacion DateTime @updatedAt

  @@map("users")
}

model Todo {
  id                 String   @id @default(uuid())
  nombre             String
  descripcion        String?
  prioridad          Priority
  finalizada         Boolean  @default(false)
  userId             String
  fechaCreacion      DateTime @default(now())
  fechaActualizacion DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("todos")
}

enum Priority {
  baja
  media
  alta
}
